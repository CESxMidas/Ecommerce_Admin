# ─── Development ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=/api
API_INTERNAL_URL=http://localhost:888

NEXTAUTH_URL=http://localhost:3001/api/next-auth
NEXTAUTH_SECRET=change-me-in-development-use-openssl-rand

# Storefront link on admin login "Forgot password"
NEXT_PUBLIC_STOREFRONT_URL=http://localhost:3000

# Dev admin seed (see README.md at repo root)
# npm run seed:admin in Ecommerce_Backend

# ─── Production ────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL=/api
# API_INTERNAL_URL=https://your-backend.onrender.com
# NEXTAUTH_URL=https://admin.your-domain.com/api/next-auth
# NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
#
# Backend CORS_ORIGIN must include admin URL:
#   CORS_ORIGIN=https://your-storefront.vercel.app,https://admin.your-domain.com
