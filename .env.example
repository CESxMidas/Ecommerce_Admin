# ─── Development ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=/api
API_INTERNAL_URL=http://localhost:888

NEXTAUTH_URL=http://localhost:3001/api/next-auth
NEXTAUTH_SECRET=change-me-in-development-use-openssl-rand

# Storefront link on admin login "Forgot password"
NEXT_PUBLIC_STOREFRONT_URL=http://localhost:3000

# Dev admin seed (see README.md at repo root)
# npm run seed:admin in Ecommerce_Backend

# ─── Production (Vercel) — set on Vercel Dashboard, not in local .env ─
# NEXT_PUBLIC_API_URL=/api
# API_INTERNAL_URL=https://ecommerce-backend-w4nx.onrender.com
# NEXTAUTH_URL=https://ecommerce-key-admin.vercel.app/api/next-auth
# NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
# NEXT_PUBLIC_STOREFRONT_URL=https://website-ecommerce-key.vercel.app
#
# Render CORS_ORIGIN:
#   https://website-ecommerce-key.vercel.app,https://ecommerce-key-admin.vercel.app
